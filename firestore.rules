rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomCode} {
      allow read, write: if true;
    }

    match /quizRooms/{roomCode} {
      allow read, write: if true;
    }

    match /quizTopics/{topicId} {
      allow read, write: if true;
    }
  }
}
